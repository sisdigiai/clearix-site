# clearix-site é estático e não precisa de secrets para build/deploy.
# Estas variáveis são opcionais, usadas só se o formulário de contato
# passar a enviar para um endpoint (2ª fase).

# Endpoint do formulário de contato (ex: webhook n8n / edge function)
PUBLIC_CONTACT_ENDPOINT=

# URL do Hub Clearix (login dos clientes existentes)
PUBLIC_HUB_URL=https://clearixhub.netlify.app
