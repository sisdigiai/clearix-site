---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroLente from '../components/HeroLente.astro';
import ProvaOperacao from '../components/ProvaOperacao.astro';
import Cuidado from '../components/Cuidado.astro';
import RiscoZero from '../components/RiscoZero.astro';
import CtaFinal from '../components/CtaFinal.astro';
import { apps, jornadas } from '../data/apps';
import { planos } from '../data/planos';
import { promessas } from '../data/prova';

const HUB = 'https://clearixhub.netlify.app';

const antes = ['20 a 40 clientes somem por mês — e ninguém liga', '4h por dia respondendo "meu óculos já tá pronto?"', 'Você não sabe qual loja lucra mais que a outra', 'Caixa, estoque e WhatsApp que não se falam'];
const depois = ['Recall com IA traz o cliente de volta — 10×', 'O laboratório avisa o paciente sozinho', 'A rede inteira numa visão só, em tempo real', 'O dado entra uma vez e flui pra todos os apps'];

const faq = [
  { q: 'Preciso trocar meu sistema inteiro de uma vez?', a: 'Não. A migração é guiada e pode ser por etapa — começamos pelo que dói mais e o resto entra no ritmo da loja.' },
  { q: 'Vocês migram meus dados antigos?', a: 'Sim. Pacientes, vendas e histórico são importados com as datas originais preservadas — sua operação não começa do zero.' },
  { q: 'Funciona com mais de uma loja?', a: 'Sim. O Clearix é multi-loja: cada unidade com seus dados, e o dono enxerga tudo numa visão só.' },
  { q: 'Meus dados de paciente ficam seguros?', a: 'Sim. Segurança por padrão: isolamento por loja, acesso por papel e portal do paciente só por link — em conformidade com a LGPD.' },
  { q: 'Como começo?', a: 'Pelo agendamento de uma demonstração. A partir dela montamos o plano de setup e migração da sua ótica.' },
];

const passos = [
  { n: '01', t: 'Demonstração', d: 'Mostramos o Clearix rodando com dados parecidos com os da sua ótica.' },
  { n: '02', t: 'Setup e migração', d: 'Importamos seu histórico e configuramos lojas, papéis e regras — sem parar a operação.' },
  { n: '03', t: 'Operação no ar', d: 'A equipe opera no Clearix, com acompanhamento próximo no começo.' },
];

const tech = ['Supabase', 'Anthropic · Claude', 'PostgreSQL'];
---

<BaseLayout>
  <!-- Hero-lente cinematográfico (scroll-scrub) — a lente Clearix focando -->
  <HeroLente />

  <!-- Painel ao vivo — "o produto é o demo" -->
  <section class="py-20 md:py-28 bg-ink-deep border-b border-clarity-off/10">
    <div class="container-grid grid md:grid-cols-12 gap-10 items-center">
      <div class="md:col-span-5">
        <p class="label mb-4">Veja rodando</p>
        <h2 class="h-section mb-4">A ótica em tempo real.</h2>
        <p class="body-lg">Não é print parado — é a operação real do dia a dia fluindo entre os apps do Clearix, numa visão só.</p>
      </div>
      <div class="md:col-span-7">
        <div class="glass rounded-xl overflow-hidden focus3d">
          <div class="flex items-center gap-2 px-4 py-3 border-b border-clarity-off/10">
            <span class="w-2.5 h-2.5 rounded-full bg-clarity-off/20"></span><span class="w-2.5 h-2.5 rounded-full bg-clarity-off/20"></span><span class="w-2.5 h-2.5 rounded-full bg-clearix-cyan/60"></span>
            <span class="ml-3 font-mono text-label-sm text-clarity-muted">clearix · painel</span>
            <span class="ml-auto flex items-center gap-2"><span class="relative flex h-2 w-2"><span class="absolute inline-flex h-full w-full rounded-full bg-clearix-cyan opacity-60 animate-ping"></span><span class="relative inline-flex h-2 w-2 rounded-full bg-clearix-cyan"></span></span><span class="font-mono text-label-sm text-clearix-cyan">ao vivo</span></span>
          </div>
          <div class="grid grid-cols-3 gap-px bg-clarity-off/10">
            <div class="bg-ink-surface p-5"><span class="block font-mono tabular-nums text-2xl text-clarity-off">20.488</span><span class="text-clarity-muted text-label-sm">vendas</span></div>
            <div class="bg-ink-surface p-5"><span class="block font-mono tabular-nums text-2xl text-clarity-off">22.299</span><span class="text-clarity-muted text-label-sm">ordens</span></div>
            <div class="bg-ink-surface p-5"><span class="block font-mono tabular-nums text-2xl text-clearix-cyan">+192</span><span class="text-clarity-muted text-label-sm">últimos 30d</span></div>
          </div>
          <div class="bg-ink-surface p-5 border-t border-clarity-off/10">
            <div class="flex items-end gap-1 h-16">
              {[35,52,40,68,55,72,60,84,70,90,78,96].map((h) => <span class="flex-1 bg-clearix-cyan/40 rounded-t-sm" style={`height:${h}%`}></span>)}
            </div>
            <span class="font-mono text-label-sm text-clarity-muted mt-3 block">vendas / mês — operação Grupo Mello</span>
          </div>
        </div>
        <p class="label-sm normal-case tracking-wide text-clarity-muted/60 mt-4">Painel ilustrativo com dados reais — evolui para clipe do Clearix em produção.</p>
      </div>
    </div>
  </section>

  <!-- Promessas / prova rápida -->
  <section class="py-16 md:py-20 border-b border-clarity-off/10">
    <div class="container-grid grid grid-cols-1 md:grid-cols-3 gap-px bg-clarity-off/10 border border-clarity-off/10 rounded-lg overflow-hidden focus3d">
      {promessas.map((p) => (
        <div class="bg-ink-surface p-8">
          <span class="block font-mono tabular-nums text-4xl text-clearix-cyan mb-2">{p.valor}</span>
          <span class="block font-display font-semibold text-lg text-clarity-off mb-1">{p.label}</span>
          <span class="block text-clarity-muted text-body-md">{p.nota}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Antes / depois -->
  <section class="py-20 md:py-28 border-b border-clarity-off/10">
    <div class="container-grid">
      <p class="label mb-4">Por que Clearix</p>
      <h2 class="h-section mb-12">Da operação no improviso ao sistema inteligente.</h2>
      <div class="grid md:grid-cols-2 gap-px bg-clarity-off/10 border border-clarity-off/10 rounded-lg overflow-hidden focus3d">
        <div class="bg-ink-base p-8">
          <p class="label-sm text-amber-400/90 mb-6">Antes — no improviso</p>
          <ul class="space-y-4">
            {antes.map((i) => <li class="flex gap-3 text-clarity-muted text-body-md"><span class="text-amber-400/70 shrink-0">✕</span>{i}</li>)}
          </ul>
        </div>
        <div class="bg-ink-surface p-8">
          <p class="label-sm text-clearix-cyan-bright mb-6">Depois — no Clearix</p>
          <ul class="space-y-4">
            {depois.map((i) => <li class="flex gap-3 text-clarity-off text-body-md"><span class="text-clearix-cyan-bright shrink-0">→</span>{i}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <ProvaOperacao />

  <!-- Cuidado — ato claro da página (Precisão e Cuidado): a lente deixa a luz passar -->
  <Cuidado />

  <!-- Depoimento (MOCK — trocar por depoimento real com nome/cargo antes de publicar) -->
  <section class="py-20 md:py-28 border-b border-clarity-off/10">
    <div class="container-grid max-w-4xl">
      <figure class="glass rounded-2xl p-8 md:p-12 focus3d">
        <div class="prism-edge h-[2px] w-20 mb-8 rounded-full"></div>
        <blockquote class="font-display font-semibold text-[22px] md:text-[30px] leading-snug tracking-tight text-clarity-off">
          “Migramos mais de cinco anos de operação para o Clearix sem parar a loja. Hoje a rede inteira está numa tela só, o laboratório avisa o cliente sozinho — e quem sumia, volta.”
        </blockquote>
        <figcaption class="mt-8 flex items-center gap-4">
          <span class="w-12 h-12 rounded-full bg-clearix-navy/40 border border-clearix-navy-soft/30 grid place-items-center font-display font-bold text-clearix-cyan-bright">GM</span>
          <span>
            <span class="block text-clarity-off font-semibold">Grupo Mello Óticas</span>
            <span class="block text-clarity-muted text-body-md">Cliente desde 2020 · 10 lojas</span>
          </span>
        </figcaption>
      </figure>
    </div>
  </section>

  <!-- Ecossistema por jornada -->
  <section class="py-20 md:py-28 bg-ink-deep border-b border-clarity-off/10">
    <div class="container-grid">
      <div class="max-w-2xl mb-12 md:mb-16">
        <p class="label mb-4">Ecossistema integrado</p>
        <h2 class="h-section">16 apps. Um ecossistema. Zero atrito.</h2>
        <p class="body-lg mt-5">Não são ferramentas soltas: cada app compartilha os mesmos dados, regras e identidade — organizados pela jornada da sua ótica.</p>
      </div>

      {jornadas.map((j, ji) => {
        const jApps = apps.filter((a) => a.jornada === j.key);
        return (
          <details class="lens-card group" open={ji === 0}>
            <summary class="lens-summary flex items-center gap-4 p-5 md:p-6 hover:bg-clearix-navy/10 transition-colors">
              <span class="grid h-9 w-9 shrink-0 place-items-center rounded-lg border border-clearix-cyan/25 bg-clearix-navy/25 font-mono text-clearix-cyan-bright text-label-sm">{String(ji + 1).padStart(2, '0')}</span>
              <span class="min-w-0 flex-1">
                <span class="flex flex-wrap items-baseline gap-x-3 gap-y-0.5">
                  <span class="font-mono text-label-md uppercase tracking-widest text-clearix-cyan">{j.titulo}</span>
                  <span class="text-clarity-muted text-body-md">{j.desc}</span>
                </span>
              </span>
              <span class="flex shrink-0 items-center gap-3">
                <span class="hidden sm:inline font-mono text-label-sm uppercase tracking-widest text-clarity-muted/80"><span class="text-clarity-off">{jApps.length}</span> apps</span>
                <span class="lens-chevron grid h-7 w-7 place-items-center rounded-full border border-clarity-off/15 text-clearix-cyan-bright" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
                </span>
              </span>
            </summary>
            <div class="lens-card-body">
              <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-clarity-off/10 border-t border-clarity-off/10">
                {jApps.map((a) => (
                  <div class="bg-ink-surface p-5 flex flex-col gap-2 transition-shadow hover:shadow-[0_0_40px_-14px_#06B6D4]">
                    <span class="flex items-center gap-2">
                      <span class="w-2 h-2 rounded-full shrink-0" style={`background:${a.cor}`}></span>
                      <span class="font-mono text-label-sm uppercase tracking-widest text-clarity-off">{a.nome}</span>
                    </span>
                    <span class="text-clarity-muted text-[13px] leading-snug">{a.tagline}</span>
                  </div>
                ))}
              </div>
            </div>
          </details>
        );
      })}
      <a href="/ecossistema" class="inline-block mt-8 font-mono text-label-md uppercase tracking-wider text-clearix-cyan hover:text-clearix-cyan-soft transition-colors">Conhecer cada app →</a>
    </div>
  </section>

  <!-- Faixa-manifesto -->
  <section data-lux class="lux-cyan relative overflow-hidden py-20 md:py-28 border-b border-clarity-off/10 text-center">
    <div class="lux-glow"></div>
    <div class="container-grid max-w-3xl relative z-10 focus3d-soft">
      <div class="prism-edge h-[2px] w-32 mx-auto mb-8 rounded-full"></div>
      <h2 class="font-display font-extrabold text-[32px] leading-tight md:text-[44px] md:leading-[1.05] tracking-[-0.03em]">
        Clareza com profundidade.<br/>
        <span class="text-clearix-cyan italic">Transformando informação em decisão.</span>
      </h2>
    </div>
  </section>

  <!-- Planos (preview) -->
  <section class="py-20 md:py-28 border-b border-clarity-off/10">
    <div class="container-grid">
      <div class="max-w-2xl mb-12 md:mb-16">
        <p class="label mb-4">Planos</p>
        <h2 class="h-section">Comece pequeno. Cresça sem trocar de sistema.</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-px bg-clarity-off/10 border border-clarity-off/10 rounded-lg overflow-hidden focus3d">
        {planos.map((p) => (
          <div class={`bg-ink-surface p-6 flex flex-col ${p.destaque ? 'ring-1 ring-clearix-cyan/40' : ''}`}>
            {p.destaque && <span class="font-mono text-label-sm uppercase tracking-widest text-clearix-cyan mb-2">Mais escolhido</span>}
            <h3 class="font-display font-semibold text-xl text-clarity-off">{p.nome}</h3>
            <p class="mt-2 mb-1"><span class="font-mono tabular-nums text-2xl text-clarity-off">{p.preco}</span><span class="text-clarity-muted text-body-md">{p.precoNota ?? ''}</span></p>
            <p class="text-clarity-muted text-[13px] mb-4">{p.apps} apps · {p.lojas}</p>
            <p class="text-clarity-dim text-body-md mt-auto">{p.publico}</p>
          </div>
        ))}
      </div>
      <a href="/planos" class="inline-block mt-8 font-mono text-label-md uppercase tracking-wider text-clearix-cyan hover:text-clearix-cyan-soft transition-colors">Ver planos e o que cada um inclui →</a>
    </div>
  </section>

  <!-- Como começar -->
  <section class="py-20 md:py-28 bg-ink-deep border-b border-clarity-off/10">
    <div class="container-grid">
      <div class="max-w-2xl mb-12 md:mb-16">
        <p class="label mb-4">Como começar</p>
        <h2 class="h-section">No ar em semanas, não meses.</h2>
        <p class="body-lg mt-5">Sem trauma de migração: a gente importa seu histórico e a loja não para.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-px bg-clarity-off/10 border border-clarity-off/10 rounded-xl overflow-hidden focus3d">
        {passos.map((p) => (
          <div class="bg-ink-surface p-8">
            <span class="font-mono tabular-nums text-4xl text-clearix-cyan-bright">{p.n}</span>
            <h3 class="font-display font-semibold text-xl mt-4 mb-2 text-clarity-off">{p.t}</h3>
            <p class="text-clarity-muted text-body-md">{p.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Aura (IA) -->
  <section data-lux class="lux-cyan relative overflow-hidden py-24 md:py-32 border-b border-clarity-off/10">
    <div class="lux-glow"></div>
    <div class="absolute -left-28 -bottom-32 w-[480px] h-[480px] opacity-50 pointer-events-none hidden md:block">
      <svg viewBox="0 0 200 200" fill="none" class="w-full h-full">
        <defs>
          <radialGradient id="lensG" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#22D3EE" stop-opacity="0.30" />
            <stop offset="45%" stop-color="#3B82F6" stop-opacity="0.10" />
            <stop offset="100%" stop-color="#3B82F6" stop-opacity="0" />
          </radialGradient>
        </defs>
        <circle cx="100" cy="100" r="70" fill="url(#lensG)" />
        <g class="lens-ccw" style="transform-origin:100px 100px">
          <circle cx="100" cy="100" r="80" stroke="#67E8F9" stroke-width="0.5" stroke-opacity="0.4" stroke-dasharray="3 7" />
          <circle cx="100" cy="100" r="64" stroke="#22D3EE" stroke-width="1.4" stroke-dasharray="48 170" stroke-opacity="0.7" />
        </g>
        <circle cx="100" cy="100" r="3" fill="#22D3EE" />
      </svg>
    </div>
    <div class="container-grid grid md:grid-cols-12 gap-8 md:gap-16 items-center relative z-10 focus3d-soft">
      <div class="md:col-span-5">
        <p class="label mb-4">Inteligência · em construção</p>
        <h2 class="h-section italic mb-2">Aura</h2>
        <p class="font-mono text-label-md uppercase tracking-wider text-clarity-muted">A camada de IA do Clearix</p>
      </div>
      <p class="md:col-span-7 body-lg">
        A Aura é a camada de inteligência do Clearix — em construção e crescendo a cada ciclo.
        Ela lê os dados reais da operação para apoiar as decisões do dia a dia da ótica, com a
        visão de fazer o ecossistema trabalhar com menos esforço e mais clareza.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 md:py-28 border-b border-clarity-off/10">
    <div class="container-grid grid md:grid-cols-12 gap-8 md:gap-16">
      <div class="md:col-span-4">
        <p class="label mb-4">Dúvidas</p>
        <h2 class="h-sub">Perguntas frequentes</h2>
      </div>
      <div class="md:col-span-8 border-t border-clarity-off/10">
        {faq.map((f) => (
          <details class="group border-b border-clarity-off/10">
            <summary class="list-none cursor-pointer flex items-center justify-between gap-4 py-5">
              <span class="font-display font-semibold text-xl">{f.q}</span>
              <span class="font-mono text-clearix-cyan text-2xl leading-none group-open:rotate-45 transition-transform">+</span>
            </summary>
            <p class="unfold3d text-clarity-muted text-body-md pb-6 max-w-2xl">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Segurança + tecnologia (autoridade) -->
  <section class="py-14 md:py-20 border-b border-clarity-off/10">
    <div class="container-grid grid md:grid-cols-12 gap-8 items-center focus3d-soft">
      <div class="md:col-span-7">
        <p class="label mb-3">Segurança por padrão</p>
        <p class="body-lg max-w-xl">
          Isolamento de dados por loja, acesso por papel e portal do paciente só por link —
          em conformidade com a LGPD. Dado clínico e financeiro tratado com rigor.
        </p>
      </div>
      <div class="md:col-span-5">
        <p class="label-sm mb-4 md:text-right">Construído sobre tecnologia de ponta</p>
        <div class="flex flex-wrap md:justify-end items-center gap-x-8 gap-y-3 font-mono text-label-md uppercase tracking-widest text-clarity-muted/80">
          {tech.map((t) => <span>{t}</span>)}
        </div>
      </div>
    </div>
  </section>

  <RiscoZero />

  <CtaFinal />
</BaseLayout>
