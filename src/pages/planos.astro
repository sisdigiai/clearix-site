---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaFinal from '../components/CtaFinal.astro';
import { planos, demo, addons } from '../data/planos';
---

<BaseLayout
  title="Planos Clearix — a partir de R$ 349/mês"
  description="Essencial, Controle, Crescimento e Completo. Comece pequeno e cresça sem trocar de sistema. Demonstração grátis por 30 dias."
>
  <!-- Hero -->
  <section data-lux class="lux-cyan relative overflow-hidden grid-bg pt-32 pb-16 md:pt-40 md:pb-20 border-b border-clarity-off/10">
    <div class="lux-glow"></div>
    <div class="container-grid max-w-3xl anim-fade-in relative z-10">
      <p class="label mb-6">Planos</p>
      <h1 class="h-display mb-6">Comece pequeno.<br/><span class="text-clearix-cyan italic">Cresça sem trocar de sistema.</span></h1>
      <p class="body-lg max-w-2xl">
        Você sobe de plano conforme a ótica cresce — sem migração, sem retrabalho, sem perder histórico.
        Os mesmos dados, mais apps liberados.
      </p>
    </div>
  </section>

  <!-- Tiers -->
  <section class="py-16 md:py-24 border-b border-clarity-off/10">
    <div class="container-grid">
      <div class="glass rounded-xl px-5 py-4 mb-8 flex flex-wrap items-center gap-3 focus3d">
        <span class="font-mono text-label-sm uppercase tracking-widest text-ink-deep bg-clearix-cyan-bright rounded px-2.5 py-1">Preço de lançamento</span>
        <span class="text-clarity-dim text-body-md">Condição das primeiras óticas — garanta agora e mantenha o valor enquanto for cliente.</span>
      </div>
      <p class="text-clarity-dim text-body-lg mb-8 max-w-3xl">
        Um só Clearix no lugar de <span class="text-clarity-off font-semibold">5 sistemas separados</span> — caixa, estoque, laboratório, CRM e financeiro. A partir de <span class="text-clearix-cyan-bright font-semibold">R$ 349/mês</span>.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-px bg-clarity-off/10 border border-clarity-off/10 rounded-lg overflow-hidden focus3d">
        {planos.map((p) => (
          <div class={`relative p-7 flex flex-col ${p.destaque ? 'bg-clearix-navy/20 ring-2 ring-inset ring-clearix-cyan-bright' : 'bg-ink-surface'}`}>
            {p.destaque && <span class="prism-edge absolute top-0 inset-x-0 h-[3px]"></span>}
            {p.destaque && <span class="font-mono text-label-sm uppercase tracking-widest text-ink-deep bg-clearix-cyan-bright rounded px-2 py-0.5 self-start mb-3">★ Mais escolhido</span>}
            {!p.destaque && <span class="h-[26px] mb-3"></span>}
            <h2 class="font-display font-bold text-2xl text-clarity-off">{p.nome}</h2>
            <p class="mt-3 mb-1">
              <span class="font-mono tabular-nums text-3xl text-clarity-off">{p.preco}</span>
              {p.precoNota && <span class="text-clarity-muted text-body-md">{p.precoNota}</span>}
            </p>
            <p class="font-mono text-label-sm uppercase tracking-wider text-clearix-cyan mb-1">{p.apps} apps</p>
            <p class="text-clarity-muted text-[13px] mb-5">{p.lojas} · {p.publico}</p>
            <ul class="space-y-2 mb-6">
              {p.inclui.map((i) => (
                <li class="flex gap-2 text-clarity-dim text-body-md"><span class="text-clearix-cyan shrink-0">→</span>{i}</li>
              ))}
            </ul>
            <a href="/contato" class={`mt-auto text-center ${p.destaque ? 'btn-primary' : 'btn-outline'} text-label-sm py-2.5`}>
              {p.preco === 'Sob consulta' ? 'Falar com a gente' : 'Começar'}
            </a>
          </div>
        ))}
      </div>
      <p class="text-clarity-muted text-body-md mt-6">
        <span class="text-clearix-cyan-bright">✓</span> 30 dias grátis, sem cartão
        <span class="text-clarity-muted/40 mx-2">·</span><span class="text-clearix-cyan-bright">✓</span> Migração guiada
        <span class="text-clarity-muted/40 mx-2">·</span><span class="text-clearix-cyan-bright">✓</span> Sobe de plano sem perder histórico
      </p>
      <p class="label-sm normal-case tracking-wide text-clarity-muted/60 mt-3">
        Preços de referência. Valores e composição confirmados na proposta. Tributos conforme legislação.
      </p>
    </div>
  </section>

  <!-- Demo -->
  <section class="py-16 md:py-20 bg-ink-deep border-b border-clarity-off/10">
    <div class="container-grid">
      <div class="card flex flex-col md:flex-row items-start md:items-center justify-between gap-6 focus3d">
        <div>
          <p class="label mb-2">{demo.preco}</p>
          <h2 class="h-sub mb-2">{demo.nome}</h2>
          <p class="text-clarity-muted text-body-md max-w-xl">{demo.desc}</p>
        </div>
        <a href="/contato" class="btn-primary shrink-0">Começar grátis</a>
      </div>
    </div>
  </section>

  <!-- Add-ons -->
  <section class="py-16 md:py-24 border-b border-clarity-off/10">
    <div class="container-grid">
      <div class="max-w-2xl mb-10">
        <p class="label mb-3">Complementos</p>
        <h2 class="h-sub">Add-ons sob medida</h2>
        <p class="body-lg mt-4">Serviços que ligam quando a ótica precisa — todos sob consulta, ativados com você.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-clarity-off/10 border border-clarity-off/10 rounded-lg overflow-hidden focus3d">
        {addons.map((a) => (
          <div class="bg-ink-surface p-6">
            <h3 class="font-display font-semibold text-lg text-clarity-off mb-1">{a.nome}</h3>
            <p class="text-clarity-muted text-body-md">{a.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaFinal titulo="Qual plano combina com a sua ótica?" texto="Conte como sua operação funciona hoje e a gente recomenda o ponto de partida certo." />
</BaseLayout>
