---
const HUB = 'https://clearixhub.netlify.app';
interface Props {
  titulo?: string;
  texto?: string;
}
const {
  titulo = 'Veja o Clearix na sua ótica.',
  texto = 'Agende uma demonstração e veja a operação inteira rodando numa só inteligência.',
} = Astro.props;
---

<section data-lux class="lux-cyan relative overflow-hidden py-28 md:py-36 text-center">
  <div class="lux-glow"></div>
  <div class="container-grid max-w-2xl relative z-10 focus3d-soft">
    <h2 class="h-section mb-6">{titulo}</h2>
    <p class="body-lg mb-10">{texto}</p>
    <div class="flex flex-wrap gap-4 justify-center">
      <a href="/contato" class="btn-primary">Começar grátis por 30 dias</a>
      <a href={HUB} target="_blank" rel="noopener" class="btn-outline">Já sou cliente →</a>
    </div>
    <p class="text-clarity-muted text-body-md mt-5">
      <span class="text-clearix-cyan-bright">✓</span> Sem cartão de crédito
      <span class="text-clarity-muted/40 mx-2">·</span><span class="text-clearix-cyan-bright">✓</span> Migração guiada
      <span class="text-clarity-muted/40 mx-2">·</span><span class="text-clearix-cyan-bright">✓</span> Cancele quando quiser
    </p>
  </div>
</section>
