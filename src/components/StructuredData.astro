---
// JSON-LD para SEO + GEO/AEO (buscadores e crawlers de IA).
// Schemas: SoftwareApplication (Clearix) + Organization (DIGIAI) + WebSite + ItemList (apps) + FAQPage.
// Dados canônicos — não inventar. Apps importados de src/data/apps.
import { apps } from '../data/apps';

const SITE = 'https://clearix.app.br';
const DIGIAI_LOGO = 'https://hswyopqvnolqpmprqvzh.supabase.co/storage/v1/object/public/digiai-brand/logo/horizontal_dark.png';

// 1) Clearix como software
const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  '@id': `${SITE}/#clearix`,
  name: 'Clearix',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  description: 'Ecossistema operacional para óticas: vendas, clínica, laboratório, financeiro, estoque, fidelidade, marketing com IA, BI e prova virtual de armações — integrados num só login.',
  url: SITE,
  image: `${SITE}/og-default.png`,
  inLanguage: 'pt-BR',
  publisher: { '@id': `${SITE}/#organization` },
  offers: [
    { '@type': 'Offer', name: 'Essencial', price: '349.00', priceCurrency: 'BRL', description: '7 apps, 1 loja', availability: 'https://schema.org/InStock' },
    { '@type': 'Offer', name: 'Controle', price: '899.00', priceCurrency: 'BRL', description: '11 apps, até 5 lojas', availability: 'https://schema.org/InStock' },
    { '@type': 'Offer', name: 'Crescimento', price: '1499.00', priceCurrency: 'BRL', description: '16 apps, até 8 lojas', availability: 'https://schema.org/InStock' },
  ],
};

// 2) DIGIAI — empresa-mãe (publisher)
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${SITE}/#organization`,
  name: 'DIGIAI',
  alternateName: 'DIGIAI ÓTICA E TECNOLOGIA LTDA',
  legalName: 'DIGIAI ÓTICA E TECNOLOGIA LTDA',
  url: 'https://digiai.app.br',
  logo: { '@type': 'ImageObject', url: DIGIAI_LOGO, width: 1200, height: 400 },
  image: DIGIAI_LOGO,
  email: 'sisdigiai@gmail.com',
  telephone: '+5511986027415',
  description: 'Empresa de tecnologia operada por IA, criadora do Clearix — o ecossistema operacional para óticas.',
  foundingDate: '2026-05-21',
  taxID: '12.549.582/0001-49',
  vatID: '12.549.582/0001-49',
  numberOfEmployees: { '@type': 'QuantitativeValue', minValue: 1, maxValue: 5 },
  knowsAbout: [
    'Gestão de óticas',
    'Software para óticas',
    'CRM óptico',
    'Prontuário eletrônico oftálmico',
    'Laboratório óptico (DCL)',
    'Prova virtual de armações (AR)',
    'IA para varejo óptico',
    'Brasil',
  ],
  founder: { '@type': 'Person', name: 'Gilberto Mello', jobTitle: 'Sócio-administrador' },
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Rua General Francisco Glicério, 940, Térreo - Sala 02, Jardim Guaio',
    addressLocality: 'Suzano',
    addressRegion: 'SP',
    postalCode: '08674-000',
    addressCountry: 'BR',
  },
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+5511986027415',
    email: 'sisdigiai@gmail.com',
    contactType: 'customer service',
    areaServed: 'BR',
    availableLanguage: ['Portuguese', 'pt-BR'],
  },
  sameAs: [
    'https://instagram.com/_digiai',
    'https://facebook.com/61586695274933',
    'https://tiktok.com/@sisdigiai',
    'https://youtube.com/@SisDigiai',
    'https://linkedin.com/company/digiai',
    'https://github.com/sisdigiai',
  ],
};

// 3) WebSite (entidade canônica do site)
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE}/#website`,
  url: SITE,
  name: 'Clearix',
  description: 'O ecossistema completo para a ótica que quer crescer com método, tecnologia e inteligência.',
  inLanguage: 'pt-BR',
  publisher: { '@id': `${SITE}/#organization` },
};

// 4) ItemList dos apps do ecossistema (bom para GEO — descreve o ecossistema aos LLMs)
const appsSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  '@id': `${SITE}/#apps`,
  name: 'Apps do ecossistema Clearix',
  numberOfItems: apps.length,
  itemListElement: apps.map((a, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'SoftwareApplication',
      name: `Clearix ${a.nome}`,
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Web',
      description: a.tagline,
      isPartOf: { '@id': `${SITE}/#clearix` },
      publisher: { '@id': `${SITE}/#organization` },
    },
  })),
};

// 5) FAQ
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${SITE}/#faq`,
  mainEntity: [
    { '@type': 'Question', name: 'Preciso trocar meu sistema inteiro de uma vez?', acceptedAnswer: { '@type': 'Answer', text: 'Não. A migração é guiada e pode ser por etapa — começamos pelo que dói mais e o resto entra no ritmo da loja.' } },
    { '@type': 'Question', name: 'Vocês migram meus dados antigos?', acceptedAnswer: { '@type': 'Answer', text: 'Sim. Pacientes, vendas e histórico são importados com as datas originais preservadas — sua operação não começa do zero.' } },
    { '@type': 'Question', name: 'Funciona com mais de uma loja?', acceptedAnswer: { '@type': 'Answer', text: 'Sim. O Clearix é multi-loja: cada unidade com seus dados, e o dono enxerga tudo numa visão só.' } },
    { '@type': 'Question', name: 'Meus dados de paciente ficam seguros?', acceptedAnswer: { '@type': 'Answer', text: 'Sim. Isolamento de dados por loja, acesso por papel e portal do paciente só por link — em conformidade com a LGPD.' } },
    { '@type': 'Question', name: 'Quanto custa?', acceptedAnswer: { '@type': 'Answer', text: 'Os planos vão de R$ 349/mês (Essencial) a R$ 1.499/mês (Crescimento), além do plano Completo sob consulta. Há demonstração grátis por 30 dias.' } },
  ],
};
---
<script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(appsSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
