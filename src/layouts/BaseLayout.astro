---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import StructuredData from '../components/StructuredData.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const SITE = 'https://clearix.app.br';
const DEFAULT_TITLE = 'Clearix — o ecossistema completo para a sua ótica';
const DEFAULT_DESC = 'Clearix: 16 apps integrados para óticas — vendas, clínica, laboratório, financeiro, estoque, fidelidade, marketing com IA e prova virtual de armações. Um só login. Por DIGIAI.';
const DEFAULT_OG = `${SITE}/og-default.png`;

const {
  title = DEFAULT_TITLE,
  description = DEFAULT_DESC,
  ogImage = DEFAULT_OG,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, SITE).href;
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="DIGIAI ÓTICA E TECNOLOGIA LTDA" />
    <meta name="theme-color" content="#0A1420" />

    <!-- GEO/AEO — política explícita para crawlers de IA -->
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow" />
    <meta name="ai-bot-policy" content="allow" />
    <meta name="ai-content-attribution" content="DIGIAI ÓTICA E TECNOLOGIA LTDA — https://clearix.app.br" />

    <!-- Verificação de buscadores — colar os tokens reais após registrar clearix.app.br -->
    {/* <meta name="msvalidate.01" content="REPLACE_WITH_BING_TOKEN" /> */}
    {/* <meta name="google-site-verification" content="REPLACE_WITH_GOOGLE_TOKEN" /> */}
    {/* <meta name="yandex-verification" content="REPLACE_WITH_YANDEX_TOKEN" /> */}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:site_name" content="Clearix" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <StructuredData />

    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- LLM discovery (formato Jeremy Howard) -->
    <link rel="alternate" type="text/markdown" href="/llms.txt" title="Resumo para LLMs" />
    <link rel="alternate" type="text/markdown" href="/llms-full.txt" title="Conteúdo completo para LLMs" />

    <ClientRouter />
  </head>
  <body class="min-h-screen bg-ink-base text-clarity-off antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- WhatsApp — micro-conversão para quem ainda está pesquisando -->
    <a
      href="https://wa.me/5511986027415?text=Quero%20conhecer%20o%20Clearix"
      target="_blank"
      rel="noopener"
      class="fixed bottom-5 right-5 z-50 inline-flex items-center gap-2 rounded-full glass px-4 py-3 text-clarity-off font-semibold text-[14px] hover:text-clearix-cyan-bright transition-colors"
      aria-label="Falar no WhatsApp"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.5 14.4c-.3-.2-1.8-.9-2-1-.3-.1-.5-.2-.7.1-.2.3-.8 1-.9 1.2-.2.2-.3.2-.6.1-.3-.2-1.3-.5-2.4-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.2-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4s1.1 2.8 1.2 3c.2.2 2.1 3.2 5 4.5.7.3 1.2.5 1.7.6.7.2 1.3.2 1.8.1.6-.1 1.8-.7 2-1.4.3-.7.3-1.3.2-1.4-.1-.1-.3-.2-.6-.3z M12 2a10 10 0 00-8.6 15l-1.3 4.8 4.9-1.3A10 10 0 1012 2z" />
      </svg>
      <span class="hidden sm:inline">Falar no WhatsApp</span>
    </a>

    <!-- Luz interativa: glow cyan segue o cursor nos elementos [data-lux] -->
    <script is:inline>
      function initLux() {
        document.querySelectorAll('[data-lux]').forEach((d) => {
          if (d.dataset.luxInit) return;
          d.dataset.luxInit = '1';
          d.addEventListener('pointermove', (e) => {
            const r = d.getBoundingClientRect();
            d.style.setProperty('--mx', ((e.clientX - r.left) / r.width * 100) + '%');
            d.style.setProperty('--my', ((e.clientY - r.top) / r.height * 100) + '%');
          });
        });
      }
      document.addEventListener('astro:page-load', initLux);
      initLux();
    </script>
  </body>
</html>
